# Google Gemini API key — enables LLM document extraction + medical-necessity reasoning.
# The app runs fully WITHOUT this key (deterministic rule engine only), so it is always demoable.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Model used for extraction + reasoning. Defaults to a fast, multimodal Gemini model.
GEMINI_MODEL=gemini-2.5-flash
